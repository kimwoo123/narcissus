# narcissus 로컬 설정 — 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env
# .env 는 .gitignore 에 걸려 커밋되지 않습니다. run.sh 가 자동 로드합니다.

# Azure DevOps — URL이 https://dev.azure.com/<ORG>/<PROJECT> 형태
ADO_ORG=
ADO_PROJECT=

# Personal Access Token — https://dev.azure.com/<ORG>/_usersSettings/tokens
#   필요한 스코프: Build (Read), Code (Read)
ADO_PAT=

# 선택: 머지 대상 브랜치 (기본 main)
# FLEETBOARD_BASE_BRANCH=main

# 선택: 포트 (기본 7777)
# FLEETBOARD_PORT=7777
